{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*"],
  "compilerOptions": {
    "outDir": "dist/main",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    },
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true
  }
}